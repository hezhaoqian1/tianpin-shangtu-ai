# AI provider selection. Keep this on the server side only.
# mock | openai | grok
MODEL_PROVIDER=mock

# Mobile app calls this endpoint for product analysis.
# Leave empty to use local mock fallback.
EXPO_PUBLIC_ANALYZE_ENDPOINT=
EXPO_PUBLIC_EDIT_ENDPOINT=
API_PORT=3001
API_HOST=0.0.0.0

# OpenAI Responses API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# xAI / Grok chat completions API
XAI_API_KEY=
XAI_MODEL=grok-4.1-fast
