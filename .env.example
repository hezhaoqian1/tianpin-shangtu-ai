# Server-side AI provider selection.
# Keep provider keys on the API server only.
# mock | openai | grok
MODEL_PROVIDER=mock

# Expo app endpoints.
# These are public URLs compiled into the app. Do not put secrets here.
# Leave empty to use local mock fallback in the app.
EXPO_PUBLIC_ANALYZE_ENDPOINT=
EXPO_PUBLIC_EDIT_ENDPOINT=
EXPO_PUBLIC_UPLOAD_ENDPOINT=
EXPO_PUBLIC_IMAGE_GENERATE_ENDPOINT=
EXPO_PUBLIC_REMOVE_BACKGROUND_ENDPOINT=

# Local API server.
# Railway injects PORT automatically, so API_PORT is mostly for local runs.
API_PORT=3001
API_HOST=0.0.0.0
PUBLIC_API_BASE_URL=

# Railway Postgres / Prisma / pg repository.
DATABASE_URL=

# OpenAI Responses API or compatible /v1 gateway.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-2

# S3-compatible object storage, such as Cloudflare R2.
# Keep keys server-side only.
STORAGE_PROVIDER=mock
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# Background removal provider.
# mock | removebg | photoroom
BACKGROUND_REMOVAL_PROVIDER=mock
REMOVEBG_API_KEY=
PHOTOROOM_API_KEY=

# xAI / Grok chat completions API
XAI_API_KEY=
XAI_MODEL=grok-4.1-fast
