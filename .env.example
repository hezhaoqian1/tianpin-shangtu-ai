# Server-side AI provider selection.
# Keep provider keys on the API server only.
# mock | openai | grok
MODEL_PROVIDER=mock

# Expo app endpoints.
# These are public URLs compiled into the app. Do not put secrets here.
# Leave empty to use local mock fallback in the app.
EXPO_PUBLIC_ANALYZE_ENDPOINT=
EXPO_PUBLIC_EDIT_ENDPOINT=

# Local API server.
# Railway injects PORT automatically, so API_PORT is mostly for local runs.
API_PORT=3001
API_HOST=0.0.0.0

# OpenAI Responses API or compatible /v1 gateway.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# xAI / Grok chat completions API
XAI_API_KEY=
XAI_MODEL=grok-4.1-fast
